{
  "name": "apex-installer",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.apex.installer",
    "productName": "APEX Installer",
    "mac": {
      "icon": "../assets/icon.png",
      "target": [{"target": "dmg", "arch": ["x64"]}],
      "identity": null,
      "darkModeSupport": true
    },
    "dmg": {
      "title": "APEX Installer",
      "backgroundColor": "#0a0a0f",
      "window": {"width": 720, "height": 520}
    },
    "directories": {"output": "dist", "buildResources": "../assets"},
    "files": ["src/**/*", "package.json"]
  }
}
